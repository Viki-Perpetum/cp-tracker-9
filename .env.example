# ===========================================
# PostgreSQL
# ===========================================
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ===========================================
# JWT — used by PostgREST, GoTrue, and Kong
# ===========================================
# This is the shared secret that signs all JWTs
JWT_SECRET=your_jwt_secret_here

# Pre-signed JWT with role=anon
ANON_KEY=your_anon_key_here

# Pre-signed JWT with role=service_role (admin access)
SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================================
# Vite app config (picked up by import.meta.env)
# ===========================================
VITE_SUPABASE_URL=your_vite_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_vite_supabase_publishable_key_here

# Microsoft SSO (Azure AD / Entra ID)
VITE_AZURE_CLIENT_ID=your_azure_app_registration_client_id_here
VITE_AZURE_TENANT_ID=your_azure_tenant_id_here
VITE_AZURE_REDIRECT_URI=http://localhost:5173
